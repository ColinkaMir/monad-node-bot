# Required: get your token from @BotFather on Telegram
BOT_TOKEN=your_telegram_bot_token_here

# Optional overrides (defaults shown)
REFERENCE_RPC=https://rpc-testnet.monadinfra.com
MAX_NODES_PER_USER=5
CHECK_INTERVAL=60
BLOCK_STUCK_MINUTES=3
LAG_THRESHOLD=10
DB_PATH=/home/admin/monad-node-bot/nodes.db
LOG_FILE=/var/log/monad-node-bot.log
